{
  "name": "contador-do-campo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"yarn workspace @cdc/api dev\" \"yarn workspace @cdc/web dev\"",
    "build": "yarn workspace @cdc/shared build && yarn workspace @cdc/api build && yarn workspace @cdc/web build",
    "lint": "yarn workspaces run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9"
  }
}
