{
  "expo": {
    "name": "Contador do Campo",
    "slug": "contador-do-campo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#16a34a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.contadordocampo.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Para fotografar notas fiscais e registrar automaticamente",
        "NSPhotoLibraryUsageDescription": "Para selecionar fotos de notas fiscais da galeria"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "package": "com.contadordocampo.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-camera", { "cameraPermission": "Para fotografar notas fiscais" }],
      ["expo-image-picker", { "photosPermission": "Para selecionar fotos de notas fiscais" }]
    ],
    "scheme": "contadordocampo",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
